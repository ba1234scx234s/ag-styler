{
  "manifest_version": 3,
  "name": "AG Styler",
  "version": "1.0.0",
  "description": "Swap fonts and customise colours on autogate.co.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["*://*.autogate.co/*"],
  "action": {
    "default_title": "AG Styler"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.autogate.co/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
